rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Login actual por cédula (sin Firebase Auth): restringir en consola según tu despliegue.
    // Ajusta estas reglas cuando migres a Firebase Authentication.
    match /clinicosdoc_user/{userId}/{document=**} {
      allow read, write: if true;
    }
    match /clinicosdoc_user/{userId} {
      allow read, write: if true;
    }
    // Pacientes globales consultorio (app Android)
    match /clinicosdoc_patients/{patientKey} {
      allow read, write: if true;
      match /documents/{docId} {
        allow read, write: if true;
      }
    }
    // Registro médico compartido (web)
    match /pacientes/{cedula} {
      allow read, write: if true;
      match /atenciones/{atencionId} {
        allow read, write: if true;
      }
    }
    match /profesionales/{cedula} {
      allow read, write: if true;
    }
    match /solicitudes/{solicitudId} {
      allow read, write: if true;
    }
  }
}
